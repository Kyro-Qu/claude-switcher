{
  "manifest_version": 3,
  "name": "Claude Cookie Switcher",
  "version": "1.1.0",
  "description": "Save and switch local Claude account cookie profiles with chrome.cookies support.",
  "permissions": [
    "browsingData",
    "cookies",
    "scripting",
    "storage",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://*.claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Claude Cookie Switcher",
    "default_popup": "popup.html"
  }
}
